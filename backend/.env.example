# ==============================================
# Urban Air Quality Intelligence — Backend env
# Copy to .env and adjust as needed.
# ==============================================

# --- App ---
APP_NAME="Urban Air Quality Intelligence"
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated list of origins. Use "*" for development only.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# --- Database ---
# SQLite (default, zero-setup) — for demo.
# Postgres example: postgresql://user:pass@host:5432/uaqi
DATABASE_URL=sqlite:///./uaqi.db

# --- Data mode ---
# mock = seeded demo data (default for hackathon)
# live  = reserved for future live feed integration
DATA_MODE=mock

# --- Demo / seed ---
SEED_ON_STARTUP=true
SEED_RANDOM_SEED=42
DEMO_DAYS_HISTORY=30
DEMO_FORECAST_HOURS=72

# --- Models ---
FORECAST_MODEL_DIR=./app/data/models
FORECAST_RETRAIN_ON_STARTUP=false

# --- Optional: live data integrations (reserved, not used in demo) ---
# OPENWEATHER_API_KEY=
# OPENAQ_API_KEY=
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
